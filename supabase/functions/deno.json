{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": [
        "no-await-in-loop",
        "no-throw-literal",
        "eqeqeq",
        "no-eval",
        "prefer-const"
      ]
    }
  }
}
